rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // بيانات المخزون والمنتجات والمصاريف والإعدادات
    match /kiko_sushi/store {
      allow read, write: if true;
    }

    // كل طلب محفوظ في Document مستقل: orders/{orderId}
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // أي مسار آخر: ممنوع
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
